{
  "name": "flocker-desktop",
  "productName": "Flocker",
  "version": "1.0.0",
  "description": "Flocker — offline poultry farm OS: feed management and record storage.",
  "main": "main.cjs",
  "author": "Flocker",
  "license": "UNLICENSED",
  "scripts": {
    "start": "electron .",
    "dist": "electron-builder",
    "publish": "electron-builder --publish always"
  },
  "build": {
    "appId": "com.flocker.desktop",
    "productName": "Flocker",
    "files": [
      "main.cjs",
      "preload.cjs",
      "app/**/*",
      "assets/**/*"
    ],
    "publish": [
      {
        "provider": "github",
        "owner": "stevemensah333-rgb",
        "repo": "flocker"
      }
    ],
    "win": {
      "target": "nsis",
      "icon": "assets/logo.png"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    },
    "mac": {
      "target": "dmg",
      "icon": "assets/logo.png"
    },
    "linux": {
      "target": "AppImage",
      "icon": "assets/logo.png"
    }
  },
  "devDependencies": {
    "electron": "^33.0.0",
    "electron-builder": "^25.1.8"
  },
  "dependencies": {
    "electron-updater": "^6.3.9"
  }
}
